{
  "server": {
    "bind": "0.0.0.0",
    "port": "9999"
  },
  "browser": {
    "extraFlags": "--no-sandbox --disable-dev-shm-usage"
  },
  "instanceDefaults": {
    "maxTabs": 10
  },
  "security": {
    "allowEvaluate": true,
    "allowDownload": true,
    "allowUpload": true,
    "idpi": {
      "enabled": true,
      "allowedDomains": [
        "localhost",
        "127.0.0.1",
        "::1",
        "fixtures"
      ]
    }
  }
}
